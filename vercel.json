{
  "version": 2,
  "routes": [
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/affiliate", "dest": "/affiliate.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/articles/(.*)", "dest": "/articles/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
