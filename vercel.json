{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/checkout", "destination": "/api/checkout.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/track", "destination": "/api/track.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": ""
        }
      ]
    }
  ]
}
